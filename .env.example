# ============================================================
# Falafel Phase 1 — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets to version control.
# ============================================================

# ---- Network ------------------------------------------------
# Avalanche Fuji Testnet RPC (public endpoint)
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# ---- Deployer -----------------------------------------------
# 0x-prefixed private key for the deploying wallet (must hold AVAX for gas)
DEPLOYER_PRIVATE_KEY=YOUR_REAL_DEPLOYER_PRIVATE_KEY

# ---- Treasury -----------------------------------------------
# Address that will receive the 11 Rat Agent NFTs
TREASURY_ADDRESS=YOUR_REAL_TREASURY_ADDRESS

# ---- ERC-6551 TBA Implementation ----------------------------
# Reference implementation: https://github.com/tokenbound/contracts
TBA_IMPL_ADDRESS=YOUR_REAL_TBA_IMPLEMENTATION_ADDRESS

# ---- RWA Token ----------------------------------------------
RWA_TOKEN_NAME=Falafel RWA Token
RWA_TOKEN_SYMBOL=FRWA

# ---- RatAgents metadata ------------------------------------
# Base IPFS URI used during mintAllRats (appends "1.json" … "11.json")
BASE_METADATA_URI=ipfs://YOUR_REAL_IPFS_BASE_CID/

# ---- AgenticCommerce ----------------------------------------
# Protocol fee in basis points (max 500 = 5%). Example: 250 = 2.5%
AGENTIC_COMMERCE_FEE_BPS=250

# ---- Deployed Contract Addresses (fill after DeployPhase1) --
AGENTIC_COMMERCE_ADDRESS=YOUR_REAL_AGENTIC_COMMERCE_ADDRESS
RAT_AGENTS_ADDRESS=YOUR_REAL_RAT_AGENTS_ADDRESS

# ---- First ERC-8183 Job ------------------------------------
WORKER_ADDRESS=YOUR_REAL_WORKER_ADDRESS
EVALUATOR_ADDRESS=                        # Leave blank for auto-approve
FIRST_JOB_PAYMENT_AVAX=0.01
FIRST_JOB_DEADLINE_HOURS=24
FIRST_JOB_METADATA_URI=ipfs://YOUR_REAL_JOB_SPEC_CID

# ---- Aleph Cloud -------------------------------------------
# Ethereum private key used to authenticate with the Aleph network
ALEPH_PRIVATE_KEY=YOUR_REAL_ALEPH_PRIVATE_KEY
ALEPH_API_URL=https://api2.aleph.im
# Aleph base VM image hash (obtain from https://aleph.im runtime catalogue)
ALEPH_RUNTIME_HASH=YOUR_REAL_ALEPH_RUNTIME_HASH
